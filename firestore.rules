rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rankings are publicly readable and writable without auth
    match /rankings/{gameType}/scores/{scoreId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['nickname', 'score', 'date'])
        && request.resource.data.score is number
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() <= 64
        && (!('country' in request.resource.data) || (request.resource.data.country is string && request.resource.data.country.size() <= 2))
        && (!('city' in request.resource.data) || (request.resource.data.city is string && request.resource.data.city.size() <= 100));
    }

    // Welcome-screen sign-ins: write-only, no auth required.
    match /users/{userId} {
      allow create: if request.resource.data.keys().hasAll(['nick', 'function', 'createdAt'])
        && request.resource.data.nick is string
        && request.resource.data.nick.size() <= 64
        && request.resource.data.function is string
        && request.resource.data.function.size() <= 32
        && (!('email' in request.resource.data) || (request.resource.data.email is string && request.resource.data.email.size() <= 256))
        && (!('termsAccepted' in request.resource.data) || request.resource.data.termsAccepted is bool);
    }

    // Everything else requires authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
